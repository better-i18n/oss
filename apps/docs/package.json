{
  "name": "docs",
  "version": "0.0.11",
  "private": true,
  "scripts": {
    "build": "next build && bun scripts/generate-mdx.ts",
    "dev": "next dev",
    "start": "serve out",
    "preview": "bun run build && wrangler pages dev out",
    "deploy": "bun run build && wrangler pages deploy out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "16.10.3",
    "fumadocs-mdx": "14.3.2",
    "fumadocs-ui": "16.10.3",
    "@better-i18n/core": "workspace:^",
    "lucide-react": "^0.577.0",
    "next": "15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.100.0"
  }
}
