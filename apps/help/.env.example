# Required: Your Better i18n project identifier (org/project format)
BETTER_I18N_PROJECT=your-org/your-project

# Required: Content API key (get from Dashboard → Settings → API Keys)
BETTER_I18N_CONTENT_API_KEY=bi_pub_xxx

# Optional: Site configuration
PUBLIC_SITE_URL=https://help.yourdomain.com
PUBLIC_SITE_NAME=Your Help Center
PUBLIC_DASHBOARD_URL=https://app.yourdomain.com
PUBLIC_DOCS_URL=https://docs.yourdomain.com
PUBLIC_LANDING_URL=https://yourdomain.com
PUBLIC_SIGNUP_URL=https://app.yourdomain.com/sign-up

# Optional: Branding
PUBLIC_LOGO_URL=
PUBLIC_ORG_URL=https://yourdomain.com
PUBLIC_ORG_LOGO_URL=https://yourdomain.com/logo.svg
PUBLIC_OG_BASE_URL=

# Optional: Social links (leave empty to hide)
PUBLIC_SOCIAL_X=
PUBLIC_SOCIAL_GITHUB=
PUBLIC_SOCIAL_YOUTUBE=
