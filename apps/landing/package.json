{
  "name": "tanstack-landing",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build && bun scripts/fix-sitemap.ts && bun scripts/build-agent-skills-index.ts && bun scripts/compress-html.ts && bun run build:worker",
    "build:worker": "esbuild worker-entry.ts --outfile=dist/worker-entry.js --format=esm --platform=neutral --log-override:ignored-bare-import=silent",
    "preview": "wrangler dev --port 8990",
    "prebuild": "bun run --filter @better-i18n/core build && bun run --filter @better-i18n/use-intl build",
    "deploy": "bun run build && wrangler deploy",
    "logs": "wrangler tail",
    "test": "vitest run"
  },
  "dependencies": {
    "@better-i18n/core": "workspace:*",
    "@better-i18n/schemas": "workspace:*",
    "@better-i18n/sdk": "^3.3.0",
    "@better-i18n/ui": "^0.2.0",
    "@better-i18n/use-intl": "workspace:*",
    "@central-icons-react/round-outlined-radius-2-stroke-2": "^1.1.226",
    "@helpway/react": "0.8.1",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@remotion/player": "^4.0.458",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "~1.169.2",
    "@tanstack/react-router-devtools": "~1.166.13",
    "@tanstack/react-start": "~1.167.65",
    "@tanstack/router-plugin": "~1.167.35",
    "@tanstack/start-server-functions-server": "^1.131.2",
    "@unitalkai/icons": "^1.0.0",
    "framer-motion": "^12.29.0",
    "html-react-parser": "^5.2.15",
    "lucide-react": "^0.577.0",
    "marked": "^15.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "remotion": "^4.0.409",
    "tailwindcss": "^4.2.4",
    "use-intl": "^4.11.0",
    "vite-tsconfig-paths": "^6.0.2",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.6.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.28.0",
    "jsdom": "^27.0.0",
    "react-grab": "latest",
    "react-scan": "^0.5.6",
    "typescript": "^5.7.2",
    "vite-plugin-minify": "^2.1.0",
    "vite": "~7.3.3",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.90.0"
  }
}
