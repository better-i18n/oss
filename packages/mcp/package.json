{
  "name": "@better-i18n/mcp",
  "version": "0.20.0",
  "description": "MCP server for Better i18n translation management - AI-powered translation workflow for Cursor, Claude, and other AI assistants",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "better-i18n-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/better-i18n/better-i18n.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://better-i18n.com",
  "bugs": {
    "url": "https://github.com/better-i18n/better-i18n/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "i18n",
    "internationalization",
    "translation",
    "better-i18n",
    "cursor",
    "claude",
    "ai",
    "openai",
    "codex",
    "localization"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/index.js",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "bun run scripts/smoke.ts",
    "clean": "rm -rf dist",
    "deploy": "npm run build && wrangler deploy -c wrangler.jsonc",
    "prepublishOnly": "npm run clean && npm run build && chmod +x ./dist/index.js ./dist/http.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@trpc/client": "^11.17.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@better-i18n/mcp-types": "workspace:*",
    "@types/node": "^20.19.39",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
